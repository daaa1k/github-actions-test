{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "helpers:pinGitHubActionDigests"],
  "minimumReleaseAge": "5 days",
  "packageRules": [
    {
      "description": "Group GitHub Actions lint tool updates (regex custom managers) into one PR",
      "groupName": "lint tools",
      "matchPackageNames": ["rhysd/actionlint", "suzuki-shunsuke/ghalint", "zizmorcore/zizmor"]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Pin actionlint git tag + commit SHA (github-tags); inline # v… comment is required for Renovate semver + digest updates",
      "managerFilePatterns": ["/^\\.github/workflows/lint-actions\\.ya?ml$/"],
      "matchStrings": [
        "ACTIONLINT_COMMIT:\\s+(?<currentDigest>[a-f0-9]{40})\\s*#\\s*(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "rhysd/actionlint",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Pin ghalint git tag + commit SHA (github-tags); inline # v… comment is required for Renovate semver + digest updates",
      "managerFilePatterns": ["/^\\.github/workflows/lint-actions\\.ya?ml$/"],
      "matchStrings": [
        "GHALINT_COMMIT:\\s+(?<currentDigest>[a-f0-9]{40})\\s*#\\s*(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "suzuki-shunsuke/ghalint",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Pin zizmor git tag + commit SHA (github-tags); inline # v… comment is required for Renovate semver + digest updates",
      "managerFilePatterns": ["/^\\.github/workflows/lint-actions\\.ya?ml$/"],
      "matchStrings": [
        "ZIZMOR_COMMIT:\\s+(?<currentDigest>[a-f0-9]{40})\\s*#\\s*(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "zizmorcore/zizmor",
      "versioningTemplate": "semver"
    }
  ]
}
